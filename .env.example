# Source website to mirror
SOURCE_HOST=www.manhwaindo.my

# Your mirror domain (leave empty for auto-detect from request)
# Example: mirror.yourdomain.com
MIRROR_HOST=

# Server port (Railway/Render set this automatically)
PORT=3000

# Custom User-Agent for requests to origin (use real browser UA to avoid bot detection)
CUSTOM_UA=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
